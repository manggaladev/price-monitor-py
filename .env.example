# Database
DATABASE_URL=sqlite:///./price_monitor.db
# DATABASE_URL=postgresql://user:password@localhost:5432/price_monitor

# Telegram Bot (Required for notifications)
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Email Notifications (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
EMAIL_FROM=your_email@gmail.com
EMAIL_TO=recipient@example.com

# Scraping Settings
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/122.0.0.0 Safari/537.36
REQUEST_DELAY=2
MAX_RETRIES=3

# Scheduler
DEFAULT_CHECK_INTERVAL=360  # in minutes (6 hours)

# Logging
LOG_LEVEL=INFO
LOG_FILE=price_monitor.log

# FastAPI (optional web interface)
API_HOST=0.0.0.0
API_PORT=8000
